<Window
    x:Class="SharpFiles.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.fontawesome.io/icons/"
    xmlns:helprs="clr-namespace:SharpFiles.MyHelpers"
    xmlns:local="clr-namespace:SharpFiles"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:SharpFiles.ViewModels"
    Title="MainWindow"
    Width="950"
    Height="650"
    MinWidth="900"
    MinHeight="600"
    Style="{StaticResource WarmWindowStyle}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.DataContext>
        <vm:ShowFilesViewModels />
    </Window.DataContext>

    <Window.Resources>
        <helprs:ExtensionToIconConverter x:Key="ExtensionToIconConverter" />
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Margin="5"
                FontFamily="Segoe UI"
                FontSize="20"
                FontStretch="Normal"
                Text="{Binding ProjectTitle}" />

            <Button
                x:Name="btnAbout"
                Grid.Column="1"
                Width="100"
                Margin="20,0,0,0"
                HorizontalAlignment="Right"
                Click="btnAbout_Click"
                Content="Acerda de..."
                Style="{StaticResource WarmButton}" />
        </Grid>

        <GroupBox
            Grid.Row="1"
            FontSize="14"
            FontWeight="DemiBold"
            Foreground="{StaticResource Brush.Text}"
            Header="Buscar la carpeta"
            Style="{StaticResource WarmGroupBox}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Grid.Column="1"
                    Margin="10,5"
                    Orientation="Horizontal">

                    <Label
                        Margin="0,0,5,0"
                        Padding="0"
                        VerticalAlignment="Center"
                        Content="Ruta en donde se encuentran los archivos:" />


                    <Button Command="{Binding SearchFolderCommand}" ToolTip="Da click aquí para escoger la carpeta">
                        <Button.Content>
                            <TextBlock
                                Width="300"
                                Padding="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                FontSize="13"
                                Foreground="{StaticResource Brush.Text}"
                                Text="{Binding RutaCarpeta}" />
                        </Button.Content>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                                Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                                <ContentPresenter />
                                            </Border>

                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>

                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="BorderBrush" Value="Black" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                    </Button>

                </StackPanel>

            </Grid>
        </GroupBox>
        <GroupBox
            Grid.Row="2"
            FontSize="14"
            FontWeight="DemiBold"
            Foreground="{StaticResource Brush.Text}"
            Header="Opciones de búsqueda"
            Style="{StaticResource WarmGroupBox}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Label
                        Content="Tipo de archivo"
                        FontSize="15"
                        Foreground="Black" />
                    <ComboBox
                        Width="100"
                        Height="35"
                        Padding="5"
                        HorizontalContentAlignment="Left"
                        VerticalContentAlignment="Center"
                        ItemsSource="{Binding FileExtensions}"
                        SelectedItem="{Binding SelectedExtension}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2" Orientation="Horizontal">
                                    <fa:ImageAwesome
                                        Width="16"
                                        Height="16"
                                        Foreground="DarkSlateGray"
                                        Icon="{Binding Converter={StaticResource ExtensionToIconConverter}}" />
                                    <TextBlock Margin="5,0" Text="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Width="150"
                    Margin="5,0"
                    HorizontalContentAlignment="Left"
                    Command="{Binding SearchFilesCommand}"
                    Style="{StaticResource WarmButton}">
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome
                            Width="15"
                            Height="15"
                            Margin="10,0,10,0"
                            Foreground="Black"
                            Icon="Search" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            FontStretch="Normal"
                            Text="Iniciar búsqueda" />
                    </StackPanel>
                </Button>

                <TextBlock
                    Grid.Column="2"
                    Margin="10,0"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource Brush.Text}"
                    Text="{Binding NumFiles}" />
            </Grid>

        </GroupBox>

        <ListView
            Grid.Row="3"
            Height="auto"
            Padding="0"
            ItemContainerStyle="{StaticResource listViewItemCompact}"
            ItemsSource="{Binding Files}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Nombre del archivo" HeaderContainerStyle="{DynamicResource CustomHeaderStyle}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource FileNameText}" Text="{Binding Name}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Mostrar ubicación" HeaderContainerStyle="{DynamicResource CustomHeaderStyle}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button
                                    Command="{Binding DataContext.ItemFileCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource btnVerUbicacion}"
                                    ToolTip="Ver ubicación del archivo">
                                    <Button.Content>
                                        <fa:ImageAwesome
                                            Width="20"
                                            Height="20"
                                            Foreground="{StaticResource Brush.Text}"
                                            Icon="FolderOpen" />
                                    </Button.Content>
                                </Button>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Ruta del archivo" HeaderContainerStyle="{DynamicResource CustomHeaderStyle}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource filePathTextBlockStyle}" Text="{Binding DirectoryName}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>

        </ListView>
    </Grid>
</Window>
