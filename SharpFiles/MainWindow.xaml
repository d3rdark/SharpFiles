<Window
    x:Class="SharpFiles.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.fontawesome.io/icons/"
    xmlns:local="clr-namespace:SharpFiles"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:SharpFiles.ViewModels"
    Title="MainWindow"
    Width="950"
    Height="650"
    MinWidth="900"
    MinHeight="600"
    MaxHeight="650"
    Style="{StaticResource WarmWindowStyle}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.DataContext>
        <vm:ShowFilesViewModels />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock
                Margin="5"
                FontFamily="Segoe UI"
                FontSize="20"
                FontStretch="Normal"
                Text="{Binding ProjectTitle}" />
        </StackPanel>

        <GroupBox
            Grid.Row="1"
            FontSize="14"
            FontWeight="DemiBold"
            Foreground="{StaticResource Brush.Text}"
            Header="Buscar la carpeta"
            Style="{StaticResource WarmGroupBox}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Grid.Column="1"
                    Margin="10,5"
                    Orientation="Horizontal">

                    <Label
                        Margin="0,0,5,0"
                        Padding="0"
                        VerticalAlignment="Center"
                        Content="Ruta en donde se encuentran los archivos:" />


                    <TextBlock
                        Width="300"
                        Padding="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="{StaticResource Brush.Text}"
                        Text="{Binding RutaCarpeta}" />
                    <!--<Border
                        Background="WhiteSmoke"
                        BorderBrush="BlanchedAlmond"
                        BorderThickness="1"
                        CornerRadius="10">
                        <TextBlock
                            Width="300"
                            Padding="10"
                            FontSize="13"
                            FontWeight="Normal"
                            Text="{Binding RutaCarpeta}" />
                    </Border>-->
                </StackPanel>
                <Grid Grid.Column="2" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button
                        Width="150"
                        VerticalAlignment="Center"
                        Command="{Binding SearchFolderCommand}"
                        Content="Examinar..."
                        Style="{StaticResource WarmButton}" />
                </Grid>
            </Grid>
        </GroupBox>

        <GroupBox
            Grid.Row="2"
            FontSize="14"
            FontWeight="DemiBold"
            Foreground="{StaticResource Brush.Text}"
            Header="Opciones de búsqueda"
            Style="{StaticResource WarmGroupBox}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Label
                        Content="Tipo de archivo"
                        FontSize="15"
                        Foreground="Black" />
                    <ComboBox
                        Width="80"
                        ItemsSource="{Binding FileExtensions}"
                        SelectedItem="{Binding SelectedExtension}" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Width="150"
                    Margin="5,0"
                    HorizontalContentAlignment="Left"
                    Command="{Binding SearchFilesCommand}">
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome
                            Width="15"
                            Height="15"
                            Margin="10,0,10,0"
                            Foreground="Black"
                            Icon="SearchPlus" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            FontStretch="Normal"
                            Text="Iniciar búsqueda" />
                    </StackPanel>
                </Button>

                <TextBlock
                    Grid.Column="2"
                    Margin="10,0"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource Brush.Text}"
                    Text="{Binding NumFiles}" />
            </Grid>

        </GroupBox>

        <ListView
            Grid.Row="3"
            Height="350"
            Padding="0"
            ItemContainerStyle="{StaticResource listViewItemCompact}"
            ItemsSource="{Binding Files}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Nombre del archivo">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource FileNameText}" Text="{Binding Name}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Accion rapida">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Mostrar ubicacion" Style="{StaticResource btnVerUbicacion}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>

        </ListView>
    </Grid>
</Window>
